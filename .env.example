# Database
POSTGRES_USER=counselorbot_user
POSTGRES_PASSWORD=change_me
POSTGRES_DB=counselorbot
# Utility lanciate dall'host (`migrate_data.py`, `check_sequences.py`)
POSTGRES_HOST=localhost
POSTGRES_HOST_PORT=5435

# JWT Secret (genera con: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change_me

# API Keys dei provider AI (lascia vuoto se non usi il provider)
# Le variabili d'ambiente hanno priorità sui valori nel database
API_KEY_OPENAI=
API_KEY_ANTHROPIC=
API_KEY_GEMINI=
API_KEY_MISTRAL=
API_KEY_OPENROUTER=
OLLAMA_BASE_URL=
# Runtime locale: 8k e permanenza breve limitano KV cache/VRAM.
OLLAMA_NUM_CTX=8192
OLLAMA_KEEP_ALIVE=5m
OLLAMA_PRELOAD=false
# llama.cpp / llama-swap (endpoint OpenAI-compatibile, con o senza /v1 finale)
LLAMACPP_BASE_URL=
# Il context di llama.cpp si fissa all'avvio del server, non nella richiesta:
# esempio: llama-server ... --ctx-size 8192

# Knowledge base collettiva: vengono iniettate solo strategie marcate approved.
STRATEGY_MEMORY_FILE=/app/knowledge/approved_strategies.md

# Estrazione locale QSA via Ollama
OPENROUTER_API_KEY=
QSA_OCR_MODEL=glm-ocr:latest
QSA_PARSER_MODEL=gemma4:e2b

# --- Auth (ai4auth forward-auth) ---
# L'autenticazione avviene al bordo (nginx auth_request -> ai4auth /verify),
# che inietta gli header Remote-User/Remote-Email/Remote-Groups.
# Gruppo che abilita la dashboard admin (default: admins)
ADMIN_GROUP=admins
# Fallback sicuro: valida la sessione sulla rete Docker condivisa con ai4auth
# quando il reverse proxy non inoltra ancora il segreto condiviso.
AI4AUTH_VERIFY_URL=http://ai4auth:9091/api/verify
# Hostname pubblico del servizio: ai4auth autorizza per-hostname (access matrix),
# quindi la verifica diretta deve presentarsi con questo Host.
AI4AUTH_PUBLIC_HOST=counselorbot-sbs.ai4educ.org
# Deve coincidere con l'header X-Forwarded-Auth-Secret impostato solo dal proxy.
# Se impostato, consente il percorso rapido tramite header autenticati del proxy.
FORWARD_AUTH_SHARED_SECRET=
